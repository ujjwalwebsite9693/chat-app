# Copy this file to .env and fill in your own values

# Port the Express/Socket.IO server listens on
PORT=5000

# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/relay-chat

# Secret used to sign JWTs - use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins for CORS
CLIENT_ORIGIN=http://localhost:5173

# Optional: enables the GIF picker. Get a free key in ~2 minutes at
# https://developers.giphy.com (create an app -> copy the API key).
# GIF search/trending simply won't work until this is set - nothing else breaks.
GIPHY_API_KEY=
